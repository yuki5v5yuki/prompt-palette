{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prompt Palette",
  "version": "0.1.0",
  "identifier": "com.prompt-palette.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Prompt Palette",
        "width": 1200,
        "height": 800,
        "resizable": true
      },
      {
        "label": "launcher",
        "title": "Prompt Palette Launcher",
        "url": "launcher.html",
        "width": 600,
        "height": 480,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
